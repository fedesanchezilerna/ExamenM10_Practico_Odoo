<odoo>
  <data>

    <!-- Vistas de academy.course -->

    <!-- Vista de lista (list) para Cursos -->
    <record model="ir.ui.view" id="view_academy_course_tree">
      <field name="name">academy.course.tree</field>
      <field name="model">academy.course</field>
      <field name="arch" type="xml">
        <list decoration-info="category == 'online'">
          <field name="name"/>
          <field name="category"/>
          <field name="duration"/>
          <field name="max_students"/>
        </list>
      </field>
    </record>

    <!-- Vista de formulario (form) para Cursos -->
    <record model="ir.ui.view" id="view_academy_course_form">
      <field name="name">academy.course.form</field>
      <field name="model">academy.course</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="category"/>
              </group>
              <group>
                <field name="duration"/>
                <field name="max_students"/>
                <field name="available_seats"/>
              </group>
            </group>
            <notebook>
              <page string="Matrículas">
                <field name="enrollment_ids">
                  <list editable="bottom">
                    <field name="student_name"/>
                    <field name="enrollment_date"/>
                    <field name="state"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Vista de búsqueda (search) para Cursos -->
    <record model="ir.ui.view" id="view_academy_course_search">
      <field name="name">academy.course.search</field>
      <field name="model">academy.course</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <field name="category"/>
          <filter string="Cursos Online" name="filter_online"
                  domain="[('category', '=', 'online')]"/>
          <group expand="0" string="Agrupar por">
            <filter string="Modalidad" name="group_category"
                    context="{'group_by': 'category'}"/>
          </group>
        </search>
      </field>
    </record>

    <!-- Acción para Cursos -->
    <record model="ir.actions.act_window" id="action_academy_course">
      <field name="name">Cursos</field>
      <field name="res_model">academy.course</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- Vistas de academy.enrollment -->

    <!-- Vista de calendario para Matrículas -->
    <record model="ir.ui.view" id="view_academy_enrollment_calendar">
      <field name="name">academy.enrollment.calendar</field>
      <field name="model">academy.enrollment</field>
      <field name="arch" type="xml">
        <calendar string="Matrículas" date_start="enrollment_date"
                  color="course_id" mode="month">
          <field name="student_name"/>
          <field name="course_id"/>
          <field name="state"/>
        </calendar>
      </field>
    </record>

    <!-- Vista de lista para Matrículas -->
    <record model="ir.ui.view" id="view_academy_enrollment_tree">
      <field name="name">academy.enrollment.tree</field>
      <field name="model">academy.enrollment</field>
      <field name="arch" type="xml">
        <list>
          <field name="student_name"/>
          <field name="enrollment_date"/>
          <field name="course_id"/>
          <field name="state"/>
        </list>
      </field>
    </record>

    <!-- Vista de formulario para Matrículas -->
    <record model="ir.ui.view" id="view_academy_enrollment_form">
      <field name="name">academy.enrollment.form</field>
      <field name="model">academy.enrollment</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="student_name"/>
                <field name="course_id"/>
              </group>
              <group>
                <field name="enrollment_date"/>
                <field name="state"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Acción para Matrículas -->
    <record model="ir.actions.act_window" id="action_academy_enrollment">
      <field name="name">Matrículas</field>
      <field name="res_model">academy.enrollment</field>
      <field name="view_mode">calendar,list,form</field>
    </record>

    <!-- Menus -->

    <!-- Menú raíz -->
    <menuitem id="menu_academy_root" name="Academia"
              sequence="10"/>

    <!-- Submenú Cursos -->
    <menuitem id="menu_academy_course" name="Cursos"
              parent="menu_academy_root"
              action="action_academy_course"
              sequence="10"/>

    <!-- Submenú Matrículas -->
    <menuitem id="menu_academy_enrollment" name="Matrículas"
              parent="menu_academy_root"
              action="action_academy_enrollment"
              sequence="20"/>

  </data>
</odoo>
